# MC-Vector direnv configuration
# Automatically loads Nix development shell when entering the directory

# Use Nix Flakes if available, otherwise fall back to shell.nix
if has nix_direnv_version || has nix; then
  if [ -f flake.nix ]; then
    use flake
  elif [ -f shell.nix ]; then
    use nix
  fi
fi

# Load .env file if it exists
dotenv_if_exists
